{
  "manifest_version": 3,
  "name": "Macondo Utils",
  "description": "Quality-of-life improvements for Macondo.",
  "version": "0.2.0",
  "icons": {
    "48": "assets/icon48.png",
    "64": "assets/icon64.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://macondo.hackclub.com/*"
      ],
      "css": [
        "styles.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
